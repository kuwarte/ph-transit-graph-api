# Application
APP_NAME=ph-transit-graph
SERVER_PORT=8080

# Database
DB_URL=jdbc:postgresql://localhost:5432/ph_transit_graph
DB_USERNAME=transituser 
DB_PASSWORD=YOUR_DATABASE_PASSWORD

# JPA
DDL_AUTO=update
SHOW_SQL=true
FORMAT_SQL=true

# JWT
JWT_SECRET=YOUR_BASE64_SECRET_KEY
JWT_EXPIRATION=86400000
